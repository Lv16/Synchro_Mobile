# Copie para .release.env e ajuste os valores para produção.

RDO_SYNC_URL=https://seu-dominio/api/mobile/v1/rdo/sync/
RDO_SYNC_BATCH_URL=https://seu-dominio/api/mobile/v1/rdo/sync/batch/
RDO_PHOTO_UPLOAD_URL=https://seu-dominio/api/mobile/v1/rdo/photo/upload/
RDO_BOOTSTRAP_URL=https://seu-dominio/api/mobile/v1/bootstrap/
RDO_AUTH_TOKEN_URL=https://seu-dominio/api/mobile/v1/auth/token/
RDO_AUTH_REVOKE_URL=https://seu-dominio/api/mobile/v1/auth/revoke/

# Opcional
RDO_TRANSLATION_URL=https://seu-dominio/api/mobile/v1/translate/preview/
# Opcional (preferencial). Se vazio, o build reaproveita RDO_TRANSLATION_URL.
RDO_TRANSLATE_PREVIEW_URL=
RDO_DEVICE_NAME=Ambipar_Supervisor
RDO_HOMOLOG_MODE=false

# Versionamento do app
BUILD_NAME=1.0.0
BUILD_NUMBER=1
